# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with Litmus
6.out
*.c
*.5
*.6
*.8

# IDEs
.idea/
.vscode/
*.swp
*.swo

# OS specific
.DS_Store
Thumbs.db

# Protobuf/Generators
*.pb.go
*_grpc.pb.go

# !! Исключаем папку pkg из игнорирования, так как там ДОЛЖЕН лежать сгенерированный код
!pkg/**/*.pb.go
!pkg/**/*_grpc.pb.go
!pkg/
